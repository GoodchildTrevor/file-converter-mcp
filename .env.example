# ── MCP Auth ──────────────────────────────────────────────
MCP_AUTH_TOKEN=changeme

# ── Storage ───────────────────────────────────────────────
FILE_EXPORT_DIR=/output
FILE_EXPORT_BASE_URL=http://localhost:9003/files

# ── Templates (optional) ──────────────────────────────────
DOCS_TEMPLATE_PATH=

# ── OpenWebUI integration (optional) ──────────────────────
OWUI_URL=
JWT_SECRET=

# ── Cleanup ───────────────────────────────────────────────
# Seconds before generated files are deleted (0 = keep forever)
FILES_DELAY=3600
PERSISTENT_FILES=false

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
